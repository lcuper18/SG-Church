# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

#################################################
# DJANGO
#################################################

DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Environment: development | production | test
DJANGO_SETTINGS_MODULE=sg_church.settings.local

#################################################
# DATABASE
#################################################

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sgchurch

#################################################
# REDIS / CELERY
#################################################

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

#################################################
# AUTHENTICATION
#################################################

# Django Auth (built-in)
# Use strong random secret in production
AUTH_SECRET_KEY=your-auth-secret-key-change-in-production

# django-allauth (Optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# OAuth Providers (Optional)
SOCIALAUTH_GOOGLE_OAUTH2_KEY=
SOCIALAUTH_GOOGLE_OAUTH2_SECRET=

#################################################
# EMAIL NOTIFICATIONS
#################################################

# Resend API (Recommended - https://resend.com)
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Church Name

# Alternative: SendGrid
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=

# Alternative: AWS SES
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# AWS_SES_REGION=us-east-1

#################################################
# SMS NOTIFICATIONS
#################################################

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

#################################################
# PAYMENT PROCESSING (Stripe)
#################################################

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Connect (for multi-tenant payments)
STRIPE_CONNECT_ENABLED=True

#################################################
# FILE STORAGE
#################################################

# AWS S3
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1

# Or use local storage (development)
# DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
# MEDIA_ROOT=media/

#################################################
# MONITORING
#################################################

# Sentry (Error tracking)
SENTRY_DSN=

#################################################
# SECURITY
#################################################

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Production security (uncomment for production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000

#################################################
# MULTI-TENANCY
#################################################

# Tenant resolution: subdomain | path
TENANT_RESOLUTION_STRATEGY=subdomain
BASE_DOMAIN=localhost:8000

#################################################
# LOGGING
#################################################

LOG_LEVEL=info

#################################################
# TESTING
#################################################

# Test database (separate)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sgchurch_test

#################################################
# OPTIONAL
#################################################

# Slack webhook for admin alerts
SLACK_WEBHOOK_URL=

#################################################
# NOTES
#################################################

# 1. Copy this file to .env for local development
# 2. For production, set these in your hosting provider
# 3. NEVER commit .env to version control
# 4. Use strong, random values for all secrets
# 5. Rotate secrets regularly
