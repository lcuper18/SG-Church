# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local or .env files to version control

#################################################
# DATABASE
#################################################

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sg_church?schema=public"

# Direct database connection (Prisma)
# Used for migrations and Prisma Studio
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sg_church?schema=public"

#################################################
# REDIS (Caching & Queues)
#################################################

# Redis connection URL
# Format: redis://[user]:[password]@hostname:port
REDIS_URL="redis://localhost:6379"

#################################################
# AUTHENTICATION (NextAuth.js)
#################################################

# NextAuth secret - MUST be random and secure in production
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"

# NextAuth URL - Your application URL
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional - for social login)

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (for admin/dev login)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

#################################################
# EMAIL NOTIFICATIONS
#################################################

# Resend API Key (Recommended)
RESEND_API_KEY=""

# From email address
EMAIL_FROM="noreply@sgchurch.app"

# Alternative: AWS SES (if using AWS instead of Resend)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_SES_FROM_EMAIL="noreply@sgchurch.app"

#################################################
# SMS NOTIFICATIONS
#################################################

# Twilio credentials
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

#################################################
# PAYMENT PROCESSING (Stripe)
#################################################

# Stripe API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""

# Stripe webhook secret (for verifying webhook signatures)
STRIPE_WEBHOOK_SECRET=""

# Stripe Connect platform account ID
STRIPE_PLATFORM_ACCOUNT_ID=""

#################################################
# FILE STORAGE
#################################################

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Alternative: AWS S3
# AWS_S3_BUCKET_NAME=""
# AWS_S3_REGION="us-east-1"
# AWS_S3_ACCESS_KEY_ID=""
# AWS_S3_SECRET_ACCESS_KEY=""

#################################################
# MONITORING & ANALYTICS
#################################################

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Vercel Analytics (if deploying to Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

#################################################
# FEATURE FLAGS
#################################################

# Enable/disable features
NEXT_PUBLIC_ENABLE_DONATIONS="true"
NEXT_PUBLIC_ENABLE_LMS="true"
NEXT_PUBLIC_ENABLE_SMS="false"
NEXT_PUBLIC_ENABLE_PWA="false"

#################################################
# APPLICATION SETTINGS
#################################################

# Environment
NODE_ENV="development" # development | production | test

# Application URL (for emails, redirects, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API Rate limiting
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="60000"

#################################################
# LOGGING
#################################################

# Log level: error | warn | info | debug
LOG_LEVEL="info"

# Pretty print logs in development
LOG_PRETTY="true"

#################################################
# SECURITY
#################################################

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://sgchurch.app"

# Session configuration
SESSION_MAX_AGE="2592000" # 30 days in seconds

#################################################
# TESTING
#################################################

# Test database (separate from development)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sg_church_test?schema=public"

#################################################
# OPTIONAL INTEGRATIONS
#################################################

# Slack webhook for notifications (admin alerts)
SLACK_WEBHOOK_URL=""

# Cloudflare Turnstile (CAPTCHA alternative)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

#################################################
# BACKGROUND JOBS
#################################################

# Job queue configuration
QUEUE_CONCURRENCY="5"
QUEUE_MAX_ATTEMPTS="3"

#################################################
# MULTI-TENANCY
#################################################

# Tenant resolution strategy: subdomain | path | header
TENANT_RESOLUTION_STRATEGY="subdomain"

# Base domain for tenants (when using subdomain strategy)
NEXT_PUBLIC_BASE_DOMAIN="sgchurch.app"

#################################################
# DEVELOPMENT ONLY
#################################################

# Skip email sending in development
SKIP_EMAIL_SENDING="false"

# Skip SMS sending in development
SKIP_SMS_SENDING="true"

# Mock payment processing
MOCK_STRIPE_PAYMENTS="false"

# Prisma Studio port
PRISMA_STUDIO_PORT="5555"

#################################################
# NOTES
#################################################

# 1. Copy this file to .env.local for local development
# 2. For production, set these in your hosting provider's environment variables
# 3. NEVER commit .env.local to version control
# 4. Use strong, random values for all secrets
# 5. Rotate secrets regularly
# 6. Use different values for development, staging, and production
